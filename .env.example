# -----------------------------------------------------------------------------
# AI Configuration (Google Gemini for briefing generation)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Text-to-speech (Google Cloud TTS)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=your_google_application_credentials_here
# -----------------------------------------------------------------------------
# Live data (OpenWeatherMap, football-data.org, GNews)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
TARGET_LOCATION=your_city_state_country_here
FOOTBALL_API_KEY=your_football_data_org_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# -----------------------------------------------------------------------------
# Networking (optional configured-network policy for advisory preflight)
# -----------------------------------------------------------------------------
HOME_SSID=your_home_wifi_ssid_here

# -----------------------------------------------------------------------------
# Browser / launcher (Full path to Chromium-based .exe)
# Machine-specific paths (Brave, Vivaldi, etc.) belong here.
# -----------------------------------------------------------------------------
CUSTOM_BROWSER_PATH=your_custom_browser_path_here

# -----------------------------------------------------------------------------
# Scanner / runtime
# -----------------------------------------------------------------------------
# Unified development mode (optional; defaults to false if unset).
# When true: suppresses configured-network warnings and production run logging.
# Gmail/Calendar remain live with masked content; model behavior uses DEV_AI_SYNTHESIS.
DEV_MODE=false

# Synthesis control flag - Evaluated ONLY when DEV_MODE=true
# Options:
#   raw (bypasses model synthesis, returns unmodified data)
#   cloud (forces fall-through execution to live cloud Gemini client API)
#   local (local Ollama synthesis with deterministic raw fallback)
# Briefing route in DEV_MODE: cloud (Gemini -> local -> raw), local (local -> raw), raw
DEV_AI_SYNTHESIS=raw

# Text-to-Speech audio control flag - Evaluated ONLY when DEV_MODE=true
# Options:
#   pyttsx3 (default local playground execution baseline - offline)
#   google (forces fall-through execution to live cloud Google TTS client API)
#   kokoro (local Kokoro ONNX model playback)
DEV_TTS_PLAYBACK=pyttsx3

# Legacy scanner.should_run() gate (optional; defaults to true if unset).
# API trigger and telemetry routes use advisory preflight and ignore this setting.
ENABLE_STARTUP_GATE=true

# Architecture Offline Isolation & Simulation (optional; defaults to false if unset).
# When true: intercepts trigger requests, simulates pipeline latency stages, 
# and returns high-contrast mock data from core/mock/telemetry.json.
DEMO_MODE=false

# Text-to-Speech playback engine override used ONLY when DEMO_MODE=true.
# Options:
#   pyttsx3 (default offline local engine)
#   google (forces playout via live cloud Google TTS client API)
#   kokoro (local Kokoro ONNX model playback)
DEMO_TTS=pyttsx3

# -----------------------------------------------------------------------------
# CORS (optional, comma-separated origins for the web HUD)
# Defaults to 127.0.0.1:8000, localhost:8000, 127.0.0.1:5500, localhost:5500
# Set this if you serve the HUD from a different port. Custom values fully
# replace the defaults — they are not merged.
# -----------------------------------------------------------------------------
APEX_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# -----------------------------------------------------------------------------
# EOD market ticker (Alpha Vantage). Optional.
# When either key is unset, GET /api/v1/market serves a simulated ticker feed
# instead of live data or an error.
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
MARKET_SYMBOLS=your_comma_separated_ticker_symbols_here
