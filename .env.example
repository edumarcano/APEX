# -----------------------------------------------------------------------------
# AI Configuration (Google Gemini for briefing generation)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Text-to-speech (Inworld AI and Google Cloud TTS)
# -----------------------------------------------------------------------------
INWORLD_API_KEY=your_inworld_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=your_google_application_credentials_here
# -----------------------------------------------------------------------------
# Live data (OpenWeatherMap, football-data.org, GNews)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
TARGET_LOCATION=your_city_state_country_here
FOOTBALL_API_KEY=your_football_data_org_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# -----------------------------------------------------------------------------
# Networking (home Wi-Fi SSID for scanner presence gate)
# -----------------------------------------------------------------------------
HOME_SSID=your_home_wifi_ssid_here

# -----------------------------------------------------------------------------
# Scanner / runtime (optional, omit or set true/false. Defaults to false if unset)
# -----------------------------------------------------------------------------
TEST_MODE=false
SHOWCASE_MODE=false

# -----------------------------------------------------------------------------
# CORS (optional, comma-separated origins for the web HUD)
# Defaults to 127.0.0.1:8000, localhost:8000, 127.0.0.1:5500, localhost:5500
# Set this if you serve the HUD from a different port. Custom values fully
# replace the defaults — they are not merged.
# -----------------------------------------------------------------------------
APEX_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
