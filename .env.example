# -----------------------------------------------------------------------------
# AI Configuration (Google Gemini for briefing generation)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Text-to-speech (Google Cloud TTS)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=your_google_application_credentials_here
# -----------------------------------------------------------------------------
# Live data (OpenWeatherMap, football-data.org, GNews)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
TARGET_LOCATION=your_city_state_country_here
FOOTBALL_API_KEY=your_football_data_org_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# -----------------------------------------------------------------------------
# Networking (home Wi-Fi SSID for scanner presence gate)
# -----------------------------------------------------------------------------
HOME_SSID=your_home_wifi_ssid_here

# -----------------------------------------------------------------------------
# Browser / launcher (Full path to Chromium-based .exe)
# Machine-specific paths (Brave, Vivaldi, etc.) belong here.
# -----------------------------------------------------------------------------
CUSTOM_BROWSER_PATH=your_custom_browser_path_here

# -----------------------------------------------------------------------------
# Scanner / runtime
# -----------------------------------------------------------------------------
# Unified development mode (optional; defaults to false if unset).
# When true: bypasses scanner hardware/cooldown gates, live Gemini, Gmail/Calendar,
# run logging, and reminder read-marking. Does not disable servers or other APIs.
DEV_MODE=false

# Synthesis control flag - Evaluated ONLY when DEV_MODE=true
# Options:
#   raw (bypasses model synthesis, returns unmodified data)
#   llm (forces fall-through execution to live cloud Gemini client API)
#   slm (default local playground execution baseline - offline placeholder)
DEV_AI_SYNTHESIS=raw

# Text-to-Speech audio control flag - Evaluated ONLY when DEV_MODE=true
# Options:
#   pyttsx3 (default local playground execution baseline - offline)
#   google (forces fall-through execution to live cloud Google TTS client API)
#   elevenlabs (isolated placeholder routing for future monthly allocation pipelines)
DEV_TTS_PLAYBACK=pyttsx3

# Production startup gate (optional; defaults to true if unset).
# When true: skip hardware/cooldown only; live APIs still run.
ENABLE_STARTUP_GATE=true

# -----------------------------------------------------------------------------
# CORS (optional, comma-separated origins for the web HUD)
# Defaults to 127.0.0.1:8000, localhost:8000, 127.0.0.1:5500, localhost:5500
# Set this if you serve the HUD from a different port. Custom values fully
# replace the defaults — they are not merged.
# -----------------------------------------------------------------------------
APEX_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
