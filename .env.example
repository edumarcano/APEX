# -----------------------------------------------------------------------------
# AI Configuration (Google Gemini for briefing generation)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Live data (OpenWeatherMap, football-data.org, GNews)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
TARGET_LOCATION=your_city_state_country_here
FOOTBALL_API_KEY=your_football_data_org_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# -----------------------------------------------------------------------------
# Networking (home Wi-Fi SSID for scanner presence gate)
# -----------------------------------------------------------------------------
HOME_SSID=your_home_wifi_ssid_here

# -----------------------------------------------------------------------------
# Scanner / runtime (optional, omit or set true/false. Defaults to false if unset)
# -----------------------------------------------------------------------------
TEST_MODE=false
SHOWCASE_MODE=false
